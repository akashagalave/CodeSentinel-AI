{
  "title": "CodeSentinel AI — Production Dashboard-1",
  "uid": "codesentinel-prod-v2",
  "schemaVersion": 38,
  "refresh": "30s",
  "panels": [

    {
      "id": 1,
      "title": "🟢 Services Health",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{namespace=\"codesentinel\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "📊 Webhooks/sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(gateway_webhooks_total[1m])",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "❌ Failed Requests",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "gateway_failed_total",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "📥 Queue Size",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 12 },
      "targets": [
        {
          "expr": "gateway_queued_total",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "⚡ Webhook Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(gateway_webhook_latency_seconds_sum[1m])",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "title": "🖥️ CPU Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"codesentinel\"}[5m])) by (pod)",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "title": "🧠 Memory Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"codesentinel\"}) by (pod)",
          "refId": "A"
        }
      ]
    },

    {
      "id": 8,
      "title": "💰 Total Cost (USD)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "review_cost_usd_total",
          "refId": "A"
        }
      ]
    },

    {
      "id": 9,
      "title": "🚨 Findings",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 32 },
      "targets": [
        {
          "expr": "increase(findings_total[5m])",
          "refId": "A"
        }
      ]
    }

  ]
}